---
---
<div class="github-activity-card">
  <img src="https://github-cards.yumeko.site/api/cards/stats?username=NayukiChiba&theme=github" alt="NayukiChiba's Github Stats" loading="lazy" />
</div>

<style>
  .github-activity-card {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex: 1;
    height: 160px;
    transition: opacity 0.3s ease;
  }

  .github-activity-card:hover {
    opacity: 0.9;
  }

  .github-activity-card img {
    max-width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 767px) {
    .github-activity-card {
      height: 145px;
      justify-content: center;
      overflow-x: auto;
    }

    .github-activity-card img {
      height: 100%;
      width: auto;
      object-fit: contain;
    }
  }
</style>
