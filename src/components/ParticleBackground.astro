---
// 几何背景 — 工程图纸风格的极简几何装饰层
// 组成：点阵网格 + 大型虚线圆环 + 旋转方框 + 对角线 + 十字标记 + 主题色点缀
// 纯 CSS 动画（GPU 合成）+ 轻量鼠标视差，受配置悬浮窗的「背景装饰」「入场动画」开关控制
---

<div id="particle-bg" class="geo-bg" aria-hidden="true">
  <!-- 点阵网格层（静态） -->
  <div class="geo-grid"></div>

  <!-- 几何元素层（鼠标视差） -->
  <div class="geo-layer" id="geo-parallax">
    <!-- 右上：大圆环组（虚线外环 + 实线内环 + 主题色弧线，缓慢旋转） -->
    <svg class="geo-rings" viewBox="0 0 800 800" fill="none">
      <circle cx="400" cy="400" r="396" class="ring-dashed"></circle>
      <circle cx="400" cy="400" r="318" class="ring-solid"></circle>
      <circle cx="400" cy="400" r="318" class="ring-accent"></circle>
      <circle cx="400" cy="400" r="240" class="ring-faint"></circle>
    </svg>

    <!-- 左下：旋转方框组 -->
    <div class="geo-square geo-square-outer"></div>
    <div class="geo-square geo-square-inner"></div>

    <!-- 左上：平行对角线组 -->
    <div class="geo-lines">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <!-- 散布的十字标记 -->
    <span class="geo-cross geo-cross-1"></span>
    <span class="geo-cross geo-cross-2"></span>
    <span class="geo-cross geo-cross-3"></span>

    <!-- 主题色点缀 -->
    <span class="geo-dot"></span>
  </div>
</div>

<style>
  .geo-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* ===== 点阵网格 ===== */
  .geo-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgba(0, 0, 0, 0.05) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
    /* 顶部稍淡，底部渐隐，让内容区呼吸 */
    mask-image: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 1) 30%,
      rgba(0, 0, 0, 0.85) 100%
    );
    -webkit-mask-image: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 1) 30%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }

  /* ===== 视差层 ===== */
  .geo-layer {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  /* ===== 右上大圆环组 ===== */
  .geo-rings {
    position: absolute;
    top: max(-32vmax, -480px);
    right: max(-26vmax, -390px);
    width: min(64vmax, 960px);
    height: min(64vmax, 960px);
    animation: geoSpin 240s linear infinite;
  }

  .ring-dashed {
    stroke: rgba(0, 0, 0, 0.09);
    stroke-width: 1;
    stroke-dasharray: 4 10;
  }

  .ring-solid {
    stroke: rgba(0, 0, 0, 0.06);
    stroke-width: 1;
  }

  .ring-faint {
    stroke: rgba(0, 0, 0, 0.035);
    stroke-width: 1;
  }

  /* 主题色弧线：内环轨道上的一段高亮弧 */
  .ring-accent {
    stroke: var(--radial-c1, #111111);
    stroke-width: 1.5;
    stroke-linecap: round;
    /* 内环周长 2π × 318 ≈ 1998，弧长 150 */
    stroke-dasharray: 150 1848;
    opacity: 0.45;
  }

  /* ===== 左下旋转方框 ===== */
  .geo-square {
    position: absolute;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .geo-square-outer {
    bottom: max(-18vmax, -270px);
    left: max(-14vmax, -210px);
    width: min(38vmax, 570px);
    height: min(38vmax, 570px);
    transform: rotate(18deg);
    animation: geoSpinReverse 300s linear infinite;
  }

  .geo-square-inner {
    bottom: max(-10vmax, -150px);
    left: max(-6vmax, -90px);
    width: min(22vmax, 330px);
    height: min(22vmax, 330px);
    border-color: rgba(0, 0, 0, 0.045);
    transform: rotate(45deg);
    animation: geoSpin 220s linear infinite;
  }

  /* ===== 左上平行对角线 ===== */
  .geo-lines {
    position: absolute;
    top: 16vh;
    left: 4vw;
    width: 180px;
    height: 180px;
    transform: rotate(-45deg);
  }

  .geo-lines span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(0, 0, 0, 0.07);
  }

  .geo-lines span:nth-child(1) { top: 0; }
  .geo-lines span:nth-child(2) { top: 14px; width: 70%; }
  .geo-lines span:nth-child(3) { top: 28px; width: 40%; }

  /* ===== 十字标记 ===== */
  .geo-cross {
    position: absolute;
    width: 14px;
    height: 14px;
  }

  .geo-cross::before,
  .geo-cross::after {
    content: '';
    position: absolute;
    background: rgba(0, 0, 0, 0.14);
  }

  .geo-cross::before {
    left: 50%;
    top: 0;
    width: 1px;
    height: 100%;
  }

  .geo-cross::after {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
  }

  .geo-cross-1 { top: 22vh; right: 38vw; }
  .geo-cross-2 { bottom: 18vh; right: 12vw; }
  .geo-cross-3 { top: 58vh; left: 10vw; }

  /* ===== 主题色点 ===== */
  .geo-dot {
    position: absolute;
    top: 34vh;
    left: 22vw;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--radial-c1, #111111);
    opacity: 0.3;
  }

  /* ===== 动画 ===== */
  @keyframes geoSpin {
    to { transform: rotate(360deg); }
  }

  @keyframes geoSpinReverse {
    from { transform: rotate(18deg); }
    to { transform: rotate(-342deg); }
  }

  /* 关闭入场动画 / 系统减少动效时停止旋转 */
  :global(html.fx-anim-off) .geo-rings,
  :global(html.fx-anim-off) .geo-square-outer,
  :global(html.fx-anim-off) .geo-square-inner {
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .geo-rings,
    .geo-square-outer,
    .geo-square-inner {
      animation: none;
    }
  }

  /* 移动端：网格变密度更低、隐藏次要装饰，保持干净 */
  @media (max-width: 768px) {
    .geo-grid {
      background-size: 24px 24px;
    }

    .geo-lines,
    .geo-cross-3 {
      display: none;
    }
  }
</style>

<script>
  // 鼠标视差：几何层轻微跟随鼠标移动（按需 rAF，静止后自动停止）
  (function initGeoParallax() {
    const layer = document.getElementById('geo-parallax');
    if (!layer) return;

    // 触屏 / 减少动效场景不启用视差
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!window.matchMedia('(hover: hover)').matches) return;

    const RANGE = 14; // 最大位移（px）
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let rafId: number | null = null;

    function loop() {
      currentX += (targetX - currentX) * 0.06;
      currentY += (targetY - currentY) * 0.06;
      layer!.style.transform = `translate3d(${currentX.toFixed(2)}px, ${currentY.toFixed(2)}px, 0)`;

      if (Math.abs(targetX - currentX) > 0.1 || Math.abs(targetY - currentY) > 0.1) {
        rafId = requestAnimationFrame(loop);
      } else {
        rafId = null;
      }
    }

    document.addEventListener(
      'mousemove',
      (e) => {
        // 动画开关关闭时不响应
        if (document.documentElement.classList.contains('fx-anim-off')) return;
        targetX = (e.clientX / window.innerWidth - 0.5) * RANGE * 2;
        targetY = (e.clientY / window.innerHeight - 0.5) * RANGE * 2;
        if (rafId === null) rafId = requestAnimationFrame(loop);
      },
      { passive: true },
    );
  })();
</script>
