---
// TocScript.astro - 目录（TOC）生成、滚动高亮、折叠、移动端抽屉
---

<script is:inline>
  (function () {
    function initToc() {
      // 顶部 TOC 标题点击折叠
      const tocHeader = document.getElementById("toc-header-clickable");
      const tocToggle = document.getElementById("toc-toggle");
      const tocNav = document.getElementById("article-toc");

      if (tocHeader && tocToggle && tocNav) {
        tocHeader.addEventListener("click", () => {
          tocNav.classList.toggle("collapsed");
          tocToggle.classList.toggle("collapsed");
        });
      }

      // 回到顶部按钮（阻止冒泡，避免触发目录折叠）
      const tocScrollTop = document.getElementById("toc-scroll-top");
      tocScrollTop?.addEventListener("click", (e) => {
        e.stopPropagation();
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      const tocContainer = document.getElementById("article-toc");
      const mobileTocContainer = document.getElementById("mobile-toc");
      const contentEl = document.querySelector(".content");

      // 移动端目录悬浮窗
      const tocFloatBtn = document.getElementById("toc-float-btn");
      const tocPanel = document.getElementById("toc-drawer");

      // 确保初始状态关闭
      tocPanel?.classList.remove("open");

      function closeTocDrawer() {
        tocPanel?.classList.remove("open");
      }

      function toggleTocPanel(e) {
        e.stopPropagation();
        tocPanel?.classList.toggle("open");
      }

      tocFloatBtn?.addEventListener("click", toggleTocPanel);

      // 点击悬浮窗外部 / Escape 关闭
      document.addEventListener("click", (e) => {
        if (!tocPanel?.classList.contains("open")) return;
        const target = e.target;
        if (tocPanel.contains(target) || tocFloatBtn?.contains(target)) return;
        closeTocDrawer();
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeTocDrawer();
      });

      if ((!tocContainer && !mobileTocContainer) || !contentEl) return;

      // 获取标题（排除文章大标题 .page-title 和 <details> 折叠块内的标题）
      const allHeadings = contentEl.querySelectorAll("h1, h2, h3, h4");
      const headings = Array.from(allHeadings).filter(
        (h) => !h.closest("details") && !h.classList.contains("page-title"),
      );

      if (headings.length === 0) {
        // 没有标题时隐藏目录栏和移动端按钮
        const sidebar = document.querySelector(".toc-sidebar");
        const mobileBtn = document.querySelector(".mobile-toc-btn");
        if (sidebar) sidebar.style.display = "none";
        if (mobileBtn) mobileBtn.style.display = "none";
        return;
      }

      // 计算树形连接线前缀：以文中最高级别标题为根（深度 0，无前缀）
      const headingLevels = headings.map((h) =>
        parseInt(h.tagName.substring(1)),
      );
      const minHeadingLevel = Math.min.apply(null, headingLevels);
      const depths = headingLevels.map((l) => l - minHeadingLevel);

      // 前缀 = 祖先延续线（│ 或空格）+ 自身连接符（├─ 或 └─）
      const treePrefixes = depths.map((depth, i) => {
        if (depth === 0) return "";
        let prefix = "";

        // 祖先列：该深度的祖先在后面还有同级兄弟时画延续线 │，否则留空
        for (let d = 1; d < depth; d++) {
          let ancestorHasNext = false;
          for (let j = i + 1; j < depths.length; j++) {
            if (depths[j] < d) break;
            if (depths[j] === d) {
              ancestorHasNext = true;
              break;
            }
          }
          prefix += ancestorHasNext ? "│  " : "   ";
        }

        // 自身连接符：同级最后一项用 └─，否则用 ├─
        let isLast = true;
        for (let j = i + 1; j < depths.length; j++) {
          if (depths[j] < depth) break;
          if (depths[j] === depth) {
            isLast = false;
            break;
          }
        }
        prefix += isLast ? "└─ " : "├─ ";
        return prefix;
      });

      // 生成目录列表
      const createTocList = (forMobile) => {
        const ul = document.createElement("ul");

        headings.forEach((heading, index) => {
          if (!heading.id) {
            heading.id = "heading-" + index;
          }

          const li = document.createElement("li");
          // 层级归一化：h1 → level-0, h2 → level-1, h3 → level-2, h4 → level-3
          const level = parseInt(heading.tagName.substring(1)) - 1;
          li.className = `toc-item level-${level}`;
          li.dataset.level = level.toString();

          const div = document.createElement("div");
          div.className = "toc-item-container";

          const a = document.createElement("a");
          a.href = "#" + heading.id;
          // 复制标题 HTML 以保留 KaTeX 公式等行内渲染结果
          a.innerHTML = heading.innerHTML;

          // 插入树形连接线前缀（顶级标题无前缀）
          if (treePrefixes[index]) {
            const prefixSpan = document.createElement("span");
            prefixSpan.className = "toc-tree-prefix";
            prefixSpan.textContent = treePrefixes[index];
            a.insertBefore(prefixSpan, a.firstChild);
          }

          a.addEventListener("click", (e) => {
            e.preventDefault();
            heading.scrollIntoView({ behavior: "smooth", block: "start" });
            history.replaceState(null, "", "#" + heading.id);
            if (forMobile) closeTocDrawer();
          });

          div.appendChild(a);
          li.appendChild(div);
          ul.appendChild(li);
        });

        return ul;
      };

      // 桌面端目录 + 层级折叠
      if (tocContainer) {
        tocContainer.appendChild(createTocList(false));

        const tocItems = tocContainer.querySelectorAll(".toc-item");
        tocItems.forEach((item, index) => {
          const currentLevel = parseInt(item.dataset.level || "0");
          const nextItem = tocItems[index + 1];
          if (!nextItem) return;

          const nextLevel = parseInt(nextItem.dataset.level || "0");
          if (nextLevel <= currentLevel) return;

          const btn = document.createElement("span");
          btn.className = "toc-collapse-btn";
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>`;

          const container = item.querySelector(".toc-item-container");
          if (container) {
            container.appendChild(btn);
            item.classList.add("has-children");
          }

          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            btn.classList.toggle("collapsed");
            const isCollapsed = btn.classList.contains("collapsed");

            for (let i = index + 1; i < tocItems.length; i++) {
              const sibling = tocItems[i];
              const siblingLevel = parseInt(sibling.dataset.level || "0");
              if (siblingLevel <= currentLevel) break;
              sibling.classList.toggle("hidden-by-parent", isCollapsed);
            }
          });
        });
      }

      // 移动端目录
      if (mobileTocContainer) {
        mobileTocContainer.appendChild(createTocList(true));
      }

      // 滚动监听：高亮当前章节
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            document
              .querySelectorAll(".toc-item a")
              .forEach((link) => link.classList.remove("active"));

            const id = entry.target.id;
            const activeLinks = document.querySelectorAll(
              `.toc-item a[href="#${id}"]`,
            );
            activeLinks.forEach((activeLink) => {
              activeLink.classList.add("active");

              // 自动滚动目录，使当前高亮项保持可见
              const nav = activeLink.closest("#article-toc");
              if (nav) {
                const linkRect = activeLink.getBoundingClientRect();
                const navRect = nav.getBoundingClientRect();
                if (linkRect.top < navRect.top || linkRect.bottom > navRect.bottom) {
                  activeLink.scrollIntoView({ behavior: "smooth", block: "center" });
                }
              }
            });
          });
        },
        { root: null, rootMargin: "-100px 0px -70% 0px", threshold: 0 },
      );

      headings.forEach((h) => observer.observe(h));
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initToc);
    } else {
      initToc();
    }
  })();
</script>
