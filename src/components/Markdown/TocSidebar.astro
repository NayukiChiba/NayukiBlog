---
// TocSidebar.astro - 桌面端目录侧边栏组件
import ArticleContentSearch from "./ArticleContentSearch.astro";
---

<aside class="toc-sidebar desktop-only">
    <div class="toc-sticky">
        <ArticleContentSearch />
        <div class="toc-header" id="toc-header-clickable">
            <span>文章目录</span>
            <span class="toc-header-actions">
                <button
                    id="toc-scroll-top"
                    class="toc-top-btn"
                    aria-label="回到顶部"
                    title="回到顶部"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="12" y1="19" x2="12" y2="5"></line><polyline
                            points="5 12 12 5 19 12"></polyline></svg
                    >
                </button>
                <button
                    id="toc-toggle"
                    class="toc-toggle"
                    aria-label="Toggle Table of Contents"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><polyline points="6 9 12 15 18 9"></polyline></svg
                    >
                </button>
            </span>
        </div>
        <nav id="article-toc"></nav>
    </div>
</aside>

<style is:global>
    /* 桌面端/移动端显示控制 */
    .desktop-only {
        display: none;
    }

    @media (min-width: 1400px) {
        .desktop-only {
            display: block;
        }
    }

    /* 侧边栏样式 - Fixed 定位在屏幕右侧 */
    .toc-sidebar {
        position: fixed;
        top: 100px;
        width: 200px;
        max-height: calc(100vh - 120px);
        overflow: hidden;
        z-index: 50;
    }

    /* 大屏幕：目录在内容右侧，距离内容有间距；视口越宽目录越宽 */
    @media (min-width: 1400px) {
        .toc-sidebar {
            left: calc(50% + var(--max-width) / 2 + 1.5rem);
        }
    }

    @media (min-width: 1500px) {
        .toc-sidebar {
            width: 240px;
        }
    }

    @media (min-width: 1600px) {
        .toc-sidebar {
            width: 290px;
        }
    }

    .toc-sidebar::-webkit-scrollbar {
        width: 4px;
    }
    .toc-sidebar::-webkit-scrollbar-thumb {
        background-color: #eee;
        border-radius: 4px;
    }
    .toc-sidebar:hover::-webkit-scrollbar-thumb {
        background-color: #ccc;
    }

    .toc-sticky {
        width: 100%;
        max-height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .toc-header {
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 1rem;
        color: var(--color-text, #111111);
        letter-spacing: 0;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        user-select: none;
    }

    .toc-header > span:first-child {
        flex: 1;
        min-width: 0;
    }

    /* 头部右侧操作区：回到顶部 + 收缩箭头 */
    .toc-header-actions {
        display: flex;
        align-items: center;
        gap: 2px;
    }

    .toc-top-btn {
        background: none;
        border: none;
        color: #333;
        cursor: pointer;
        padding: 3px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        transition: background-color 0.2s ease, color 0.2s ease;
    }

    .toc-top-btn:hover {
        color: #111;
        background-color: rgba(0, 0, 0, 0.07);
    }

    .toc-toggle {
        background: none;
        border: none;
        color: #333;
        cursor: pointer;
        padding: 3px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        transition: transform 0.3s ease, background-color 0.2s ease, color 0.2s ease;
    }

    .toc-toggle:hover {
        color: #111;
        background-color: rgba(0, 0, 0, 0.07);
    }

    .toc-toggle.collapsed {
        transform: rotate(-90deg);
    }

    #article-toc {
        transition:
            max-height 0.3s ease,
            opacity 0.3s ease;
        max-height: calc(100vh - 250px);
        flex: 1;
        min-height: 0;
        opacity: 1;
        overflow-y: auto;
        overflow-x: hidden;
        overscroll-behavior: contain;
    }

    #article-toc.collapsed {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
    }

    /* 目录滚动条美化 */
    #article-toc::-webkit-scrollbar {
        width: 4px;
    }
    #article-toc::-webkit-scrollbar-thumb {
        background-color: transparent;
        border-radius: 4px;
    }
    #article-toc:hover::-webkit-scrollbar-thumb {
        background-color: #ccc;
    }

    #article-toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    #article-toc li {
        margin: 0;
        line-height: 1;
    }

    /* 仿照 Astro Pure 风格：左侧线条 + 缩进 */
    #article-toc a {
        text-decoration: none;
        color: #666;
        font-size: 0.9rem;
        transition: all 0.2s;
        display: block;
        border-left: 3px solid transparent; /* Cleaner default */
        padding: 0.6rem 0.8rem 0.6rem 1rem;
        line-height: 1.5;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
        min-width: 0;
        border-radius: 0 6px 6px 0; /* Modern touch */
    }

    /* 大纲中的 KaTeX 公式：跟随目录字号，不放大 */
    #article-toc a .katex {
        font-size: 1em;
    }

    #article-toc a:hover {
        color: var(--color-primary, #111111);
        border-left-color: var(--color-primary, #111111);
        background-color: var(--color-primary-subtle, rgba(0, 0, 0, 0.04));
    }

    #article-toc a.active {
        color: var(--color-primary, #111111);
        font-weight: 600;
        border-left-color: var(--color-primary, #111111);
        background-color: var(--color-primary-subtle, rgba(0, 0, 0, 0.04));
    }

    /* TOC 容器布局 */
    .toc-item-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    /* 折叠按钮样式 — 明显的可点击箭头 */
    .toc-collapse-btn {
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #444;
        border-radius: 6px;
        transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
        z-index: 2;
        margin-left: auto;
        margin-right: 0.25rem;
        flex-shrink: 0;
    }

    .toc-collapse-btn:hover {
        color: #111;
        background-color: rgba(0, 0, 0, 0.07);
    }

    .toc-collapse-btn.collapsed {
        transform: rotate(-90deg);
    }

    /* 隐藏状态 */
    .toc-item.hidden-by-parent {
        display: none;
    }

    /* 目录层级：层级关系由 JS 注入的树形连接线前缀表示，缩进统一 */
    .toc-item.level-0 {
        margin-top: 0.25rem;
    }
    #article-toc .toc-item.level-0 a {
        font-weight: 600;
    }

    .toc-item.level-1 {
        margin-top: 0.15rem;
    }
    .toc-item.level-2 {
        margin-top: 0.15rem;
    }
    .toc-item.level-3 {
        margin-top: 0.1rem;
    }

    #article-toc .toc-item a {
        padding-left: 0.5rem;
    }

    /* 树形连接线前缀：等宽字体保证竖线与连接符纵向对齐 */
    #article-toc .toc-tree-prefix {
        color: #cccccc;
        font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
        white-space: pre;
        font-size: 0.9em;
    }

    /* 悬停/高亮时连接线跟随主题色 */
    #article-toc .toc-item a:hover .toc-tree-prefix,
    #article-toc .toc-item a.active .toc-tree-prefix {
        color: var(--color-primary, #111111);
    }

    /* 层级分隔线：每个顶级标题（除第一个）上方都有分隔线 */
    #article-toc .toc-item.level-0:not(:first-child) {
        margin-top: 0.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }
</style>
