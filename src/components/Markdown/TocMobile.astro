---
// TocMobile - 移动端目录悬浮球 + 悬浮窗组件
// 悬浮球位于右下角配置按钮上方，点击弹出目录悬浮窗
---

<!-- 移动端目录悬浮球 -->
<button
    class="mobile-toc-btn mobile-only"
    id="toc-float-btn"
    aria-label="文章目录"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <line x1="8" y1="6" x2="21" y2="6"></line>
        <line x1="8" y1="12" x2="21" y2="12"></line>
        <line x1="8" y1="18" x2="21" y2="18"></line>
        <line x1="3" y1="6" x2="3.01" y2="6"></line>
        <line x1="3" y1="12" x2="3.01" y2="12"></line>
        <line x1="3" y1="18" x2="3.01" y2="18"></line>
    </svg>
</button>

<!-- 移动端目录悬浮窗 -->
<div class="mobile-toc-panel" id="toc-drawer">
    <div class="toc-panel-head">文章目录</div>
    <nav class="toc-panel-content" id="mobile-toc"></nav>
</div>

<style is:global>
    /* ====== 移动端目录悬浮球 ====== */
    /* 默认位置：右下角配置按钮（fx-trigger）正上方 */
    .mobile-toc-btn {
        position: fixed;
        /* 配置按钮 bottom 2rem + 高 48px + 间距 12px */
        bottom: calc(2rem + 48px + 12px);
        right: 2rem;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #ffffff;
        border: 1px solid var(--color-border, #e5e5e5);
        color: var(--color-text, #111111);
        box-shadow: var(--shadow-md, 0 4px 12px rgba(0, 0, 0, 0.07));
        cursor: pointer;
        z-index: 9998;
        align-items: center;
        justify-content: center;
        transition:
            border-color 0.25s ease,
            box-shadow 0.25s ease;
    }

    .mobile-toc-btn:hover {
        border-color: var(--color-text, #111111);
        box-shadow: var(--shadow-lg, 0 12px 28px -8px rgba(0, 0, 0, 0.12));
    }

    /* ====== 目录悬浮窗 ====== */
    .mobile-toc-panel {
        position: fixed;
        /* 悬浮球上方 */
        bottom: calc(2rem + 48px + 12px + 48px + 12px);
        right: 2rem;
        width: min(300px, calc(100vw - 3rem));
        max-height: 55vh;
        background: #ffffff;
        border: 1px solid var(--color-border, #e5e5e5);
        border-radius: 14px;
        box-shadow: 0 16px 48px -12px rgba(0, 0, 0, 0.18);
        z-index: 9998;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform-origin: bottom right;
        transition: opacity 0.18s ease, transform 0.18s ease;
        opacity: 0;
        transform: translateY(6px) scale(0.98);
        pointer-events: none;
    }

    .mobile-toc-panel.open {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    .toc-panel-head {
        padding: 0.875rem 1rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--color-text, #111111);
        letter-spacing: 0.02em;
        border-bottom: 1px solid var(--color-border-light, #f0f0f0);
        flex-shrink: 0;
        user-select: none;
    }

    .toc-panel-content {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
        overscroll-behavior: contain;
    }

    /* 移动端（<=768px）：对齐更小的配置按钮（44px / 1.5rem） */
    @media (max-width: 768px) {
        .mobile-toc-btn {
            bottom: calc(1.5rem + 44px + 12px);
            right: 1.5rem;
            width: 44px;
            height: 44px;
        }

        .mobile-toc-panel {
            bottom: calc(1.5rem + 44px + 12px + 44px + 12px);
            right: 1.5rem;
        }
    }

    /* 桌面端（>=1400px，有侧边目录）隐藏移动端目录组件 */
    @media (min-width: 1400px) {
        .mobile-toc-btn,
        .mobile-toc-panel {
            display: none !important;
        }
    }

    /* ====== 目录列表样式 ====== */
    #mobile-toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    #mobile-toc li {
        margin: 0;
        line-height: 1;
    }

    #mobile-toc a {
        text-decoration: none;
        color: var(--color-text-light, #525252);
        font-size: 0.875rem;
        display: block;
        padding: 0.625rem 0.75rem;
        border-left: 2px solid transparent;
        border-radius: 0 6px 6px 0;
        transition: all 0.2s;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    #mobile-toc a:hover {
        color: var(--color-primary, #111111);
        border-left-color: var(--color-primary, #111111);
        background: var(--color-primary-subtle, rgba(0, 0, 0, 0.04));
    }

    #mobile-toc a.active {
        color: var(--color-primary, #111111);
        font-weight: 600;
        border-left-color: var(--color-primary, #111111);
        background: var(--color-primary-subtle, rgba(0, 0, 0, 0.04));
    }

    /* 目录层级缩进 */
    #mobile-toc .level-1 a {
        padding-left: 0.75rem;
    }
    #mobile-toc .level-2 a {
        padding-left: 1.5rem;
    }
    #mobile-toc .level-3 a {
        padding-left: 2.25rem;
        font-size: 0.8125rem;
    }
    #mobile-toc .level-4 a {
        padding-left: 3rem;
        font-size: 0.8125rem;
    }
</style>
