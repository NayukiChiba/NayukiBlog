---
// 静态预渲染
export const prerender = true;

import PageLayout from "../layouts/PageLayout.astro";
import PostCard from "../components/articles/PostCard.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import ProfileCard from "../components/index/ProfileCard.astro";


import DiaryCard from "../components/DiaryCard.astro";
import { getVisiblePosts } from "../lib/posts";
import { getProjects, getDiaries } from "../lib/data";

// 获取文章列表（最新3篇；生产环境只含 published，开发环境含 draft）
const allPosts = await getVisiblePosts();
const posts = allPosts
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
  )
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    date: post.data.date,
    desc: post.data.description,
    url: `/posts/${post.slug}`,
    category: post.data.category,
    tags: post.data.tags,
    image: post.data.image,
  }));

// 获取项目列表（优先显示进行中的项目，最多2个）
const allProjects = getProjects();
const inProgressProjects = allProjects.filter(
  (p) => p.status === "in-progress",
);
const displayProjects =
  inProgressProjects.length > 0 ? inProgressProjects : allProjects;
const projects = displayProjects.slice(0, 2).map((project) => ({
  title: project.name,
  desc: project.description,
  url: project.link,
  tech: project.techStack,
}));

// 获取最新日记
const allDiaries = getDiaries();
const latestDiary = allDiaries.length > 0 ? allDiaries[0] : null;

// 格式化日记日期（和 DiaryCard 保持一致）
let formattedDiaryDate = "";
if (latestDiary) {
  const d = new Date(latestDiary.date);
  formattedDiaryDate = isNaN(d.getTime())
    ? latestDiary.date
    : d.getFullYear() +
      "-" +
      String(d.getMonth() + 1).padStart(2, "0") +
      "-" +
      String(d.getDate()).padStart(2, "0") +
      " " +
      String(d.getHours()).padStart(2, "0") +
      ":" +
      String(d.getMinutes()).padStart(2, "0");
}

// 统计文章数、标签数、分类数
const articleCount = allPosts.length;
const tagSet = new Set(allPosts.flatMap((p) => p.data.tags || []));
const categorySet = new Set(allPosts.map((p) => p.data.category).filter(Boolean));
---

<PageLayout title="Nayuki Blog">
  <div class="home-container">
    <!-- Profile Section (Top) -->
    <section class="profile-section">
      <div class="profile-wrapper">
        <ProfileCard />

        <div class="profile-divider"></div>

        <div class="stats-card">
          <div class="stat-item">
            <span class="stat-number">{articleCount}</span>
            <span class="stat-label">文章</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{tagSet.size}</span>
            <span class="stat-label">标签</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{categorySet.size}</span>
            <span class="stat-label">分类</span>
          </div>
        </div>

        <div class="profile-divider"></div>

        <div class="hitokoto-area">
          <span id="hitokoto-text"></span>
          <span class="hitokoto-cursor">|</span>
          <span class="hitokoto-from" id="hitokoto-from"></span>
        </div>
      </div>
    </section>

    <!-- GitHub Activity Graph -->
    <section class="section-block github-graph-section">
      <div class="github-graph-wrapper">
        <div class="github-graph-placeholder">
          <span>Loading contributions...</span>
        </div>
        <img
          src="https://activity.yumeko.site/graph?username=NayukiChiba&theme=xcode&bg_color=FF000000&color=000000&hide_border=true"
          alt="GitHub Activity Graph"
          class="github-graph-img"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
          onload="this.style.opacity='1';this.previousElementSibling.style.display='none'"
        />
      </div>
    </section>

    <div class="divider"></div>

    <!-- Latest Diary (Conditional) -->
    {
      latestDiary && (
        <section class="section-block">
          <div class="section-header">
            <h2 class="section-title">Latest Diary</h2>
            <a href="/diary" class="view-all">
              View all →
            </a>
          </div>
          <div class="diary-preview">
            <div class="diary-expanded">
              <div class="diary-header">
                <div class="meta-group">
                  <span class="meta-item" title="Date">
                    📅 {formattedDiaryDate}
                  </span>
                  {latestDiary.weather && (
                    <span class="meta-item" title="Weather">
                      {latestDiary.weather === "sunny"
                        ? "☀️"
                        : latestDiary.weather === "cloudy"
                          ? "☁️"
                          : latestDiary.weather === "rainy"
                            ? "🌧️"
                            : latestDiary.weather === "snowy"
                              ? "❄️"
                              : latestDiary.weather === "windy"
                                ? "💨"
                                : "🌤️"}
                      <span class="meta-text">{latestDiary.weather}</span>
                    </span>
                  )}
                  <span class="meta-item" title="Mood">
                    {latestDiary.mood === "happy"
                      ? "😊"
                      : latestDiary.mood === "excited"
                        ? "🤩"
                        : latestDiary.mood === "sad"
                          ? "😢"
                          : latestDiary.mood === "angry"
                            ? "😠"
                            : latestDiary.mood === "tired"
                              ? "😫"
                              : latestDiary.mood === "relieved"
                                ? "😌"
                                : "😐"}
                    <span class="meta-text">{latestDiary.mood}</span>
                  </span>
                </div>
              </div>
              <div class="diary-body">
                <p>{latestDiary.content}</p>
                {latestDiary.images && latestDiary.images.length > 0 && (
                  <div class="diary-images">
                    {latestDiary.images.map((img: string) => (
                      <img src={img} alt="Diary attachment" loading="lazy" />
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- Latest Posts -->
    <section class="section-block">
      <div class="section-header">
        <h2 class="section-title">Latest Posts</h2>
        <a href="/articles" class="view-all">View all →</a>
      </div>
      <div class="post-list">
        {posts.map((post: any) => <PostCard {...post} />)}
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="section-block">
      <div class="section-header">
        <h2 class="section-title">Featured Projects</h2>
        <a href="/projects" class="view-all">View all →</a>
      </div>
      <div class="project-grid">
        {projects.map((project: any) => <ProjectCard {...project} />)}
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .home-container {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Staggered Animation for Sections */
  .home-container > section,
  .home-container > .divider {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .home-container > *:nth-child(1) {
    animation-delay: 0.1s;
  }
  .home-container > *:nth-child(2) {
    animation-delay: 0.15s;
  }
  .home-container > *:nth-child(3) {
    animation-delay: 0.2s;
  }
  .home-container > *:nth-child(4) {
    animation-delay: 0.25s;
  }
  .home-container > *:nth-child(5) {
    animation-delay: 0.3s;
  }
  .home-container > *:nth-child(6) {
    animation-delay: 0.35s;
  }

  /* GitHub Activity Graph */
  .github-graph-section {
    margin-top: -3rem;
    margin-bottom: 2rem;
  }

  /* 移动端：取消负边距，避免与上方内容重叠 */
  @media (max-width: 767px) {
    .github-graph-section {
      margin-top: 0;
    }
  }

  .github-graph-wrapper {
    position: relative;
  }

  .github-graph-img {
    width: 100%;
    border-radius: 12px;
    display: block;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .github-graph-placeholder {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  /* Stats Card */
  .stats-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex: 1;
    height: 160px;
  }

  /* 移动端：去掉固定高度，内容居中、紧凑排列 */
  @media (max-width: 767px) {
    .stats-card {
      height: auto;
      padding: 0.25rem 0;
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Hitokoto */
  .hitokoto-area {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    font-size: 0.9rem;
    color: var(--color-text);
    height: 160px;
    flex: 1;
    flex-wrap: wrap;
    padding-top: 2rem;
  }

  .hitokoto-cursor {
    animation: blink 1s step-end infinite;
    color: var(--color-primary);
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .hitokoto-from {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: 0.5rem;
  }

  @media (min-width: 768px) {
    .hitokoto-area {
      width: 220px;
      flex-shrink: 0;
    }
  }

  /* 移动端：名人名言去固定高度、文字居中 */
  @media (max-width: 767px) {
    .hitokoto-area {
      height: auto;
      padding-top: 0;
      justify-content: center;
      text-align: center;
    }
  }

  /* Profile Section */
  .profile-section {
    margin-bottom: 4rem;
  }

  .profile-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* 移动端：整体紧凑、各区块居中 */
  @media (max-width: 767px) {
    .profile-section {
      margin-bottom: 2.5rem;
    }

    .profile-wrapper {
      gap: 1.5rem;
      align-items: center;
    }
  }

  .profile-divider {
    display: none;
    width: 1px;
    height: 60px;
    background: linear-gradient(
      180deg,
      transparent,
      var(--color-border),
      transparent
    );
    margin: 0;
  }

  @media (min-width: 768px) {
    .profile-wrapper {
      flex-direction: row;
      align-items: center;
    }

    .profile-divider {
      display: block;
    }
  }

  .divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border) 20%,
      var(--color-border) 80%,
      transparent
    );
    margin: 3rem 0 4rem 0;
    position: relative;
  }

  .divider::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--color-bg);
  }

  /* Section Styles */
  .section-block {
    margin-bottom: 5rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 700;
    margin: 0;
    color: var(--color-text);
    position: relative;
    padding-left: 1.125rem;
    letter-spacing: -0.02em;
  }

  .section-title::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 1.4em;
    background: linear-gradient(
      180deg,
      var(--color-primary),
      var(--color-primary-light)
    );
    border-radius: 2px;
  }

  .view-all {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
    position: relative;
  }

  .view-all::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width 0.3s ease;
  }

  .view-all:hover {
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .view-all:hover::after {
    width: 60%;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Diary Preview Styles */
  .diary-preview {
    position: relative;
    padding-left: 2rem;
    border-left: 2px solid var(--color-primary-light);
    margin-left: 1rem;
  }

  .diary-preview::before {
    content: "";
    position: absolute;
    left: -6px;
    top: 0;
    width: 10px;
    height: 10px;
    background: var(--color-primary);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--color-bg);
  }

  .diary-expanded {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: visible;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .diary-expanded:hover {
    border-color: var(--color-text, #111111);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .diary-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .meta-group {
    display: flex;
    gap: 1.75rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s ease;
  }

  .meta-item:hover {
    color: var(--color-primary);
  }

  .meta-text {
    text-transform: capitalize;
  }

  .diary-body p {
    margin: 0;
    line-height: 1.8;
    color: var(--color-text-light);
    font-size: 1rem;
    white-space: pre-wrap;
  }

  .diary-images {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .diary-images img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .diary-images img:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* 移动端响应式优化 */
  @media (max-width: 767px) {
    .profile-section {
      margin-bottom: 2.5rem;
    }

    .divider {
      margin: 2rem 0 3rem 0;
    }

    .section-block {
      margin-bottom: 3.5rem;
    }

    .section-header {
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-size: 1.375rem;
    }

    .view-all {
      font-size: 0.875rem;
    }

    .diary-preview {
      padding-left: 1.25rem;
      margin-left: 0.5rem;
    }

    .post-list {
      gap: 1rem;
    }
  }
</style>

<script>
  const textEl = document.getElementById('hitokoto-text');
  const fromEl = document.getElementById('hitokoto-from');
  if (textEl && fromEl) {
    let currentText = '';
    let charIdx = 0;
    let isDeleting = false;
    let typingTimer: ReturnType<typeof setTimeout>;

    async function fetchHitokoto(): Promise<{ text: string; from: string }> {
      try {
        const res = await fetch('https://v1.hitokoto.cn/');
        const data = await res.json();
        return { text: data.hitokoto, from: data.from ? `—— ${data.from}` : '' };
      } catch {
        return { text: '生活明朗，万物可爱。', from: '—— 佚名' };
      }
    }

    function typeWriter(text: string, from: string) {
      clearTimeout(typingTimer);

      if (!isDeleting) {
        textEl!.textContent = text.substring(0, charIdx + 1);
        charIdx++;
        if (charIdx <= text.length) {
          typingTimer = setTimeout(() => typeWriter(text, from), 80);
        } else {
          fromEl!.textContent = from;
          isDeleting = true;
          typingTimer = setTimeout(() => typeWriter(text, from), 4000);
        }
      } else {
        textEl!.textContent = text.substring(0, charIdx - 1);
        fromEl!.textContent = '';
        charIdx--;
        if (charIdx > 0) {
          typingTimer = setTimeout(() => typeWriter(text, from), 30);
        } else {
          isDeleting = false;
          fetchAndType();
        }
      }
    }

    async function fetchAndType() {
      const { text, from } = await fetchHitokoto();
      currentText = text;
      charIdx = 0;
      isDeleting = false;
      fromEl!.textContent = '';
      typeWriter(currentText, from);
    }

    // 每分钟换一句
    setInterval(() => {
      isDeleting = true;
      typeWriter(currentText, '');
    }, 60000);

    fetchAndType();
  }
</script>

<script>
  // 激活文章卡片的懒加载图片（home 页无分页，直接全部加载）
  function loadPostCardImages() {
    const images = document.querySelectorAll<HTMLImageElement>(
      '.post-bg-image img[data-src]',
    );
    images.forEach((img) => {
      if (img.dataset.src && !img.src) {
        img.src = img.dataset.src;
        img.onload = () => img.classList.add('loaded');
        img.onerror = () => img.classList.add('loaded');
      }
    });
  }

  loadPostCardImages();
  document.addEventListener('astro:page-load', loadPostCardImages);
</script>
