---
import { getVisiblePosts } from "../lib/posts";
import PageLayout from "../layouts/PageLayout.astro";
import PostCard from "../components/articles/PostCard.astro";
import CategorySidebar from "../components/articles/CategorySidebar.astro";
import TagSidebar from "../components/articles/TagSidebar.astro";
import ArticleSearch from "../components/articles/ArticleSearch.astro";

// 从 Content Collections 读取文章（生产环境只含 published，开发环境含 draft）
const allPosts = await getVisiblePosts();

// 转换为页面需要的格式
const posts = allPosts
    .map((post) => ({
        title: post.data.title,
        date: post.data.date,
        desc: post.data.description || "",
        url: `/posts/${post.slug}`,
        tags: post.data.tags || [],
        image: post.data.image || "",
        folder: post.data.category || "",
        status: post.data.status || "published",
        // 提取正文用于内容搜索，去除 markdown 语法后取前 3000 字
        body: (post.body || "").replace(/[#*`\[\]()>!_|~]/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 3000),
    }))
    .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const isDev = import.meta.env.DEV;
const draftCount = posts.filter((post) => post.status === "draft").length;

const tagCounts = posts
    .flatMap((post) => post.tags || [])
    .reduce<Record<string, number>>((acc, tag) => {
        acc[tag] = (acc[tag] || 0) + 1;
        return acc;
    }, {});

const publishedTagSet = new Set<string>();
posts.forEach((post) => {
    if (post.status === "published") {
        (post.tags || []).forEach((tag: string) => publishedTagSet.add(tag));
    }
});

const tagsWithCount = Object.entries(tagCounts)
    .map(([tag, count]) => ({
        tag,
        count: count as number,
        hasPublished: publishedTagSet.has(tag),
    }))
    .sort((a, b) => a.tag.localeCompare(b.tag));

// Folder Logic
const folderSet = new Set<string>();
const publishedFolderSet = new Set<string>();

const addFolderAncestors = (targetSet: Set<string>, path: string) => {
    const parts = path.split("/");
    let current = "";
    parts.forEach((part) => {
        current = current ? `${current}/${part}` : part;
        targetSet.add(current);
    });
};

posts.forEach((post) => {
    if (post.folder) {
        addFolderAncestors(folderSet, post.folder);

        if (post.status === "published") {
            addFolderAncestors(publishedFolderSet, post.folder);
        }
    }
});

const folderList = [...folderSet].sort().map((path) => {
    const level = path.split("/").length - 1;
    const name = path.split("/").pop();
    const hasChildren = [...folderSet].some(
        (p) => p.startsWith(path + "/") && p !== path,
    );
    return {
        path,
        name: name || "",
        level,
        hasChildren,
        hasPublished: publishedFolderSet.has(path),
    };
});
---

<PageLayout title="Articles | Nayuki Blog">
    <div class="articles-container">
        <main class="page-main">
            <h1 class="page-title">文章与笔记</h1>
            <p class="page-desc">技术教程、学习笔记与思考。</p>

            <div class="content-divider"></div>

            <div class="main-layout">
                <div class="post-list-section">
                    <ArticleSearch />

                    {
                        isDev && draftCount > 0 && (
                            <div class="draft-toggle-panel" id="draft-toggle-panel">
                                <label class="draft-toggle">
                                    <input
                                        id="draft-toggle-input"
                                        type="checkbox"
                                        class="draft-toggle-input"
                                    />
                                    <span class="draft-toggle-track" aria-hidden="true">
                                        <span class="draft-toggle-thumb"></span>
                                    </span>
                                    <span class="draft-toggle-text">
                                        显示草稿
                                        <span class="draft-toggle-count">{draftCount}</span>
                                    </span>
                                </label>
                            </div>
                        )
                    }

                    <div class="post-list">
                        {
                            posts.map((post: any) => (
                                <div
                                    class="post-wrapper"
                                    data-tags={post.tags ? post.tags.join(",") : ""}
                                    data-folder={post.folder || ""}
                                    data-title={post.title}
                                    data-desc={post.desc}
                                    data-content={post.body}
                                    data-status={post.status}
                                >
                                    <PostCard {...post} />
                                </div>
                            ))
                        }
                    </div>

                    <div class="pagination">
                        <!-- ... pagination buttons ... -->
                        <button id="first-btn" class="page-btn" title="First Page" disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 17 6 12 11 7"></polyline><polyline points="18 17 13 12 18 7"></polyline></svg>
                        </button>
                        <button id="prev-btn" class="page-btn" title="Previous Page" disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        </button>

                        <div class="page-input-container">
                            <input type="number" id="page-input" class="page-input" min="1" value="1" />
                            <span class="page-separator">/</span>
                            <span id="total-pages">1</span>
                        </div>

                        <button id="next-btn" class="page-btn" title="Next Page" disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        </button>
                        <button id="last-btn" class="page-btn" title="Last Page" disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"></polyline><polyline points="6 17 11 12 6 7"></polyline></svg>
                        </button>
                    </div>
                </div>

                <!-- Desktop Sidebar -->
                <aside class="filters-sidebar desktop-only">
                    <CategorySidebar folders={folderList} />
                    <div class="sidebar-divider"></div>
                    <TagSidebar tags={tagsWithCount} />
                </aside>
            </div>
        </main>
    </div>

    <!-- Mobile Filter Button -->
    <button class="mobile-filter-btn mobile-only" id="mobile-filter-toggle" aria-label="筛选">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <span>筛选</span>
    </button>

    <!-- Mobile Drawer -->
    <div class="mobile-drawer-overlay mobile-only" id="mobile-drawer-overlay"></div>
    <div class="mobile-drawer mobile-only" id="mobile-drawer">
        <!-- 左侧关闭按钮 -->
        <button class="drawer-close-arrow" id="mobile-drawer-close" aria-label="关闭">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            <span>筛选</span>
        </button>
        <div class="drawer-main">
            <div class="drawer-header">
                <span class="drawer-title">筛选文章</span>
            </div>
                <div class="drawer-content">
                    <CategorySidebar folders={folderList} />
                    <div class="sidebar-divider"></div>
                    <TagSidebar tags={tagsWithCount} />
                </div>
        </div>
    </div>
</PageLayout>

<script>
    function initArticlesPage() {
        const folderBtns = document.querySelectorAll(".folder-btn");
        const allPostWrappers = Array.from(document.querySelectorAll(".post-wrapper")) as HTMLElement[];

        const firstBtn = document.getElementById("first-btn") as HTMLButtonElement;
        const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
        const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;
        const lastBtn = document.getElementById("last-btn") as HTMLButtonElement;
        const pageInput = document.getElementById("page-input") as HTMLInputElement;
        const totalPagesSpan = document.getElementById("total-pages");

        const tagBtns = document.querySelectorAll(".tag-btn");
        const ITEMS_PER_PAGE = 10;
        let currentPage = 1;
        let currentTag = "";
        let currentFolder = "";
        let currentSearch = "";
        let showDrafts = false;
        let visiblePosts: HTMLElement[] = [];
        const draftToggleInput = document.getElementById("draft-toggle-input") as HTMLInputElement | null;

        const hasPublishedPostInFolder = (folderPath: string) =>
            allPostWrappers.some((el) => {
                const folder = el.dataset.folder || "";
                const status = el.dataset.status || "published";
                return status !== "draft" && (folder === folderPath || folder.startsWith(folderPath + "/"));
            });

        const hasPublishedPostWithTag = (tag: string) =>
            allPostWrappers.some((el) => {
                const tags = el.dataset.tags?.split(",") || [];
                const status = el.dataset.status || "published";
                return status !== "draft" && tags.includes(tag);
            });

        const updateDraftFilterControls = () => {
            document.querySelectorAll<HTMLElement>(".folder-item[data-path]").forEach((item) => {
                const hasPublished = item.dataset.hasPublished === "true";
                item.classList.toggle("draft-filtered", !showDrafts && !hasPublished);
            });

            document.querySelectorAll<HTMLElement>(".tag-btn[data-tag]").forEach((btn) => {
                const tag = btn.dataset.tag || "";
                if (!tag) return;

                const hasPublished = btn.dataset.hasPublished === "true";
                btn.classList.toggle("draft-filtered", !showDrafts && !hasPublished);
            });

            if (!showDrafts && currentFolder && !hasPublishedPostInFolder(currentFolder)) {
                currentFolder = "";
                updateActiveState(".folder-btn", "folder", "");
            }

            if (!showDrafts && currentTag && !hasPublishedPostWithTag(currentTag)) {
                currentTag = "";
                updateActiveState(".tag-btn", "tag", "");
            }
        };

        // 加载单个卡片的封面图片（priority 控制浏览器抓取优先级）
        const loadImage = (el: HTMLElement, priority: "high" | "low") => {
            const img = el.querySelector('.post-bg-image img[data-src]') as HTMLImageElement | null;
            if (img && img.dataset.src && !img.src) {
                img.setAttribute("fetchpriority", priority);
                img.src = img.dataset.src;
                img.onload = () => img.classList.add('loaded');
                img.onerror = () => img.classList.add('loaded');
            }
        };

        // ... Pagination logic (keep as is) ...
        const updatePagination = () => {
            const totalPages = Math.ceil(visiblePosts.length / ITEMS_PER_PAGE) || 1;
            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;
            const start = (currentPage - 1) * ITEMS_PER_PAGE;
            const end = start + ITEMS_PER_PAGE;
            allPostWrappers.forEach((el) => (el.style.display = "none"));
            visiblePosts.slice(start, end).forEach((el) => {
                el.style.display = "block";
                // 当前页可见图片：高优先级立即加载
                loadImage(el, "high");
            });

            if (pageInput) {
                pageInput.value = currentPage.toString();
                pageInput.max = totalPages.toString();
            }
            if (totalPagesSpan) totalPagesSpan.textContent = totalPages.toString();
            if (firstBtn) firstBtn.disabled = currentPage === 1;
            if (prevBtn) prevBtn.disabled = currentPage === 1;
            if (nextBtn) nextBtn.disabled = currentPage === totalPages;
            if (lastBtn) lastBtn.disabled = currentPage === totalPages;
        };

        const filterPosts = () => {
            updateDraftFilterControls();

            const query = currentSearch.toLowerCase().trim();
            visiblePosts = allPostWrappers.filter((el) => {
                const tags = el.dataset.tags?.split(",") || [];
                const folder = el.dataset.folder || "";
                const status = el.dataset.status || "published";
                const matchTag = !currentTag || tags.includes(currentTag);
                const matchFolder = !currentFolder || folder === currentFolder || folder.startsWith(currentFolder + "/");
                const matchStatus = showDrafts || status !== "draft";

                // 模糊搜索：标题、简介、正文
                let matchSearch = true;
                if (query) {
                    const title = (el.dataset.title || "").toLowerCase();
                    const desc = (el.dataset.desc || "").toLowerCase();
                    const content = (el.dataset.content || "").toLowerCase();
                    matchSearch = title.includes(query) || desc.includes(query) || content.includes(query);
                }

                return matchTag && matchFolder && matchStatus && matchSearch;
            });
            currentPage = 1;
            updatePagination();

            // 通知搜索组件更新结果提示
            document.dispatchEvent(
                new CustomEvent('article:search-result', { detail: { query, count: visiblePosts.length } })
            );
        };

        // ... Pagination event listeners (keep as is) ...
        const goToPage = (page: number) => {
            const totalPages = Math.ceil(visiblePosts.length / ITEMS_PER_PAGE) || 1;
            if (page >= 1 && page <= totalPages) {
                currentPage = page;
                updatePagination();
                window.scrollTo({ top: 0, behavior: "smooth" });
            }
        };

        firstBtn?.addEventListener("click", () => goToPage(1));
        lastBtn?.addEventListener("click", () => {
            const totalPages = Math.ceil(visiblePosts.length / ITEMS_PER_PAGE) || 1;
            goToPage(totalPages);
        });
        prevBtn?.addEventListener("click", () => goToPage(currentPage - 1));
        nextBtn?.addEventListener("click", () => goToPage(currentPage + 1));
        pageInput?.addEventListener("change", () => {
            let page = parseInt(pageInput.value);
            if (isNaN(page)) page = 1;
            goToPage(page);
            pageInput.value = currentPage.toString();
        });
        pageInput?.addEventListener("keydown", (e) => {
            if (e.key === "Enter") pageInput.blur();
        });

        // Sync Active State Helper
        const updateActiveState = (selector: string, dataAttr: string, value: string) => {
            const btns = document.querySelectorAll(selector);
            btns.forEach(btn => {
                const btnValue = (btn as HTMLElement).dataset[dataAttr] || "";
                if (btnValue === value) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
        };

        // 監听搜索组件派发的事件
        document.addEventListener('article:search', (e: Event) => {
            currentSearch = (e as CustomEvent<{ query: string }>).detail.query;
            filterPosts();
        });

        if (draftToggleInput) {
            showDrafts = localStorage.getItem("articles:show-drafts") === "true";
            draftToggleInput.checked = showDrafts;

            if (!(draftToggleInput as any)._draftToggleBound) {
                (draftToggleInput as any)._draftToggleBound = true;
                draftToggleInput.addEventListener("change", () => {
                    showDrafts = draftToggleInput.checked;
                    localStorage.setItem("articles:show-drafts", String(showDrafts));
                    filterPosts();
                });
            }
        }

        // Filter Logic
        tagBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const tag = (btn as HTMLElement).dataset.tag || "";
                currentTag = tag;
                updateActiveState('.tag-btn', 'tag', tag);
                filterPosts();
                if (window.innerWidth <= 1024 && (window as any).closeMobileDrawer) {
                    (window as any).closeMobileDrawer();
                }
            });
        });

        folderBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const folder = (btn as HTMLElement).dataset.folder || "";
                currentFolder = folder;
                updateActiveState('.folder-btn', 'folder', folder);
                filterPosts();
                if (window.innerWidth <= 1024 && (window as any).closeMobileDrawer) {
                    (window as any).closeMobileDrawer();
                }
            });
        });

        // 读取 URL 参数，支持从文章页面点击 tag 跳转
        const urlParams = new URLSearchParams(window.location.search);
        const tagParam = urlParams.get('tag');
        if (tagParam) {
            currentTag = tagParam;
            updateActiveState('.tag-btn', 'tag', tagParam);
        }

        // Initial load
        filterPosts();

        // 后台预加载全部封面图片：当前页已高优先级加载，
        // 其余在浏览器空闲时以低优先级加载，翻页时图片即时可用
        const preloadRestImages = () => {
            allPostWrappers.forEach((el) => loadImage(el, "low"));
        };
        if ("requestIdleCallback" in window) {
            requestIdleCallback(preloadRestImages, { timeout: 3000 });
        } else {
            setTimeout(preloadRestImages, 1500);
        }
    }

    // Mobile Drawer Logic
    function initMobileDrawer() {
        const drawer = document.getElementById('mobile-drawer');
        const overlay = document.getElementById('mobile-drawer-overlay');
        const toggleBtn = document.getElementById('mobile-filter-toggle');
        const closeBtn = document.getElementById('mobile-drawer-close');

        function openMobileDrawer() {
            drawer?.classList.add('active');
            overlay?.classList.add('active');
            // 锁定页面滚动
            document.body.style.overflow = 'hidden';
            document.documentElement.style.overflow = 'hidden';
            // 隐藏展开按钮
            if (toggleBtn) toggleBtn.style.display = 'none';
        }

        function closeMobileDrawer() {
            drawer?.classList.remove('active');
            overlay?.classList.remove('active');
            // 恢复页面滚动
            document.body.style.overflow = '';
            document.documentElement.style.overflow = '';
            // 显示展开按钮
            if (toggleBtn) toggleBtn.style.display = 'flex';
        }

        // 直接绑定事件，避免克隆节点问题
        toggleBtn?.removeEventListener('click', openMobileDrawer);
        toggleBtn?.addEventListener('click', openMobileDrawer);
        
        closeBtn?.removeEventListener('click', closeMobileDrawer);
        closeBtn?.addEventListener('click', closeMobileDrawer);
        
        overlay?.removeEventListener('click', closeMobileDrawer);
        overlay?.addEventListener('click', closeMobileDrawer);

        // 暴露 closeMobileDrawer 到 window 供筛选后调用
        (window as any).closeMobileDrawer = closeMobileDrawer;
    }

    // Initialize
    initArticlesPage();
    initMobileDrawer();
    document.addEventListener('astro:page-load', () => {
        initArticlesPage();
        initMobileDrawer();
    });
</script>

<style is:global>
    /* Global override for width - 80% */
    main {
        max-width: 80% !important;
        width: 80% !important;
        margin: 0 auto !important;
        padding: 2rem 0 !important; 
    }
    
    @media (max-width: 1400px) {
        main {
            max-width: 90% !important;
            width: 90% !important;
        }
    }

    @media (max-width: 1023px) {
        main {
            max-width: 100% !important;
            width: 100% !important;
            padding: 1rem !important;
        }
    }
</style>

<style>
    .articles-container {
        /* Remove grid styles as we moved to flex inside main-layout */
        display: block;
    }

    .page-main {
        min-width: 0;
        width: 100%;
    }

    .page-title {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }
    .page-desc {
        color: var(--color-text-light);
        margin-bottom: 2rem;
    }

    .content-divider {
        height: 1px;
        background: var(--color-border);
        margin: 2rem 0;
        width: 100%;
    }

    .main-layout {
        display: flex;
        gap: 3rem; /* Increased gap for better separation */
        align-items: flex-start;
        max-width: 100%; /* Ensure it fills the container */
    }

    .post-list-section {
        flex: 3; /* 60% relative to sidebar's 1 (approx) */
        min-width: 0;
    }

    .post-list-section :global(.article-search) {
        margin-bottom: 1.5rem;
    }

    .draft-toggle-panel {
        display: flex;
        justify-content: flex-end;
        margin: -0.5rem 0 1.5rem;
    }

    .draft-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.5rem 0.75rem;
        border: 1.5px solid var(--color-border);
        border-radius: 10px;
        background: var(--color-bg);
        color: var(--color-text-light);
        cursor: pointer;
        user-select: none;
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease,
            color 0.2s ease;
    }

    .draft-toggle:hover,
    .draft-toggle:focus-within {
        border-color: var(--color-primary);
        color: var(--color-primary-dark);
        box-shadow: 0 0 0 3px var(--color-primary-subtle);
    }

    .draft-toggle-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .draft-toggle-track {
        width: 34px;
        height: 20px;
        border-radius: var(--radius-full);
        background: var(--color-border);
        padding: 2px;
        transition: background 0.2s ease;
        flex-shrink: 0;
    }

    .draft-toggle-thumb {
        display: block;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--color-card-bg);
        box-shadow: var(--shadow-xs);
        transition: transform 0.2s ease;
    }

    .draft-toggle-input:checked + .draft-toggle-track {
        background: var(--color-primary);
    }

    .draft-toggle-input:checked + .draft-toggle-track .draft-toggle-thumb {
        transform: translateX(14px);
    }

    .draft-toggle-text {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.85rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .draft-toggle-count {
        min-width: 1.35rem;
        height: 1.35rem;
        padding: 0 0.4rem;
        border-radius: var(--radius-full);
        background: var(--color-bg-secondary);
        color: var(--color-text-muted);
        font-size: 0.72rem;
        line-height: 1.35rem;
        text-align: center;
    }

    /* Sidebar */
    .filters-sidebar {
        flex: 1; /* 20% relative to list's 3 (approx) */
        min-width: 250px;
        max-width: 320px;
        flex-shrink: 0;
        position: sticky;
        top: 2rem;
        background: var(--color-card-bg);
        padding: 1.5rem;
        border-radius: 12px;
        margin-top: 0;
        
        /* Limit height to ~1200px or viewport, whichever is smaller */
        max-height: none;
        overflow-y: auto;
        
        /* Custom Scrollbar for Sidebar */
        scrollbar-width: thin;
        scrollbar-color: var(--color-border) transparent;
    }
    
    .filters-sidebar::-webkit-scrollbar {
        width: 6px;
    }
    .filters-sidebar::-webkit-scrollbar-track {
        background: transparent;
    }
    .filters-sidebar::-webkit-scrollbar-thumb {
        background-color: var(--color-border);
        border-radius: 20px;
    }

    .sidebar-divider {
        height: 1px;
        background: var(--color-border);
        margin: 1.5rem 0;
    }

    :global(.folder-item.draft-filtered),
    :global(.tag-btn.draft-filtered) {
        display: none !important;
    }

    .post-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Pagination */
    .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
    }
    .page-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 1px solid var(--color-border);
        background: var(--color-bg-secondary);
        border-radius: var(--radius-md);
        cursor: pointer;
        color: var(--color-text-light);
        transition: all 0.2s ease;
    }
    .page-btn:hover:not(:disabled) {
        background: var(--color-primary-subtle);
        color: var(--color-primary-dark);
        border-color: var(--color-primary-light);
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }
    .page-btn:disabled {
