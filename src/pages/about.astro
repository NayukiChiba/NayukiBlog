---
// 🚀 静态预渲染
export const prerender = true;

import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="About Me | Nayuki Blog">
    <div class="container readme-style">
        <div class="profile-header">
            <div class="avatar-container">
                <img src="/profile.jpg" alt="Nayuki" class="avatar" onerror="this.src='https://ui-avatars.com/api/?name=Nayuki&background=0D8ABC&color=fff'"/>
            </div>
            <h1 class="profile-name">卟瓿钚</h1>
        </div>

        <p class="center-text">
            <a href="https://github.com/NayukiChiba">
                <img src="https://readme-typing-svg.demolab.com?font=Fira+Code&weight=600&size=28&duration=3000&pause=1000&color=6AD3F7&center=true&vCenter=true&random=false&width=500&lines=Hi+there+%F0%9F%91%8B+I'm+MekoNayuki;Welcome+to+my+GitHub+Profile!" alt="Typing SVG" />
            </a>
        </p>

        <p class="center-text">
            🎓 <b>学生</b> | 热爱编程与人工智能
        </p>
        
        <div class="intro-text" style="text-align: center; margin: 2rem 0; color: var(--color-text-light);">
            <p>这里是我的个人博客，平常写一些自己的小巧思，日常</p>
            <p>目前是武汉大学数学系大四在读</p>
            <p>即将成为武汉大学人工智能学院研究生</p>
            <p>我的邮箱是: MekoNayuki@gmail.com</p>
        </div>

        <hr />
        
        <h2>经历</h2>
        <div class="experience-grid">
            <!-- 卡片: 武汉大学 -->
            <a href="https://www.whu.edu.cn/" target="_blank" class="xp-card">
                <div class="xp-icon">
                    <img
                        src="https://img.yumeko.site/file/blog/WHU.png"
                        alt="武汉大学"
                        style="margin: 0;"
                    />
                </div>
                <div class="xp-info">
                    <span class="xp-title">武汉大学</span>
                    <span class="xp-desc"
                        >本科 / 数据科学与大数据技术</span
                    >
                </div>
                <div class="xp-arrow">↗</div>
            </a>

            <a href="https://sai.whu.edu.cn/" target="_blank" class="xp-card">
                <div class="xp-icon">
                    <img
                        src="https://img.yumeko.site/file/blog/WHU.png"
                        alt="武汉大学"
                        style="margin: 0;"
                    />
                </div>
                <div class="xp-info">
                    <span class="xp-title">武汉大学人工智能学院</span>
                    <span class="xp-desc">研究生 / 人工智能</span>
                </div>
                <div class="xp-arrow">↗</div>
            </a>
        </div>
        

        <hr />

        <h2>技术栈</h2>

        <p class="center-flex-wrap">
            <a href="https://www.java.com/" target="_blank" rel="noopener noreferrer" aria-label="Java">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg" height="48" width="48" alt="Java" />
            </a>

            <a href="https://www.rust-lang.org/" target="_blank" rel="noopener noreferrer" aria-label="Rust">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/rust/rust-plain.svg" height="48" width="48" alt="Rust" />
            </a>

            <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" aria-label="Astro">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" height="48" width="48" alt="Astro" />
            </a>

            <a href="https://developer.mozilla.org/docs/Web/JavaScript" target="_blank" rel="noopener noreferrer" aria-label="JavaScript">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" height="48" width="48" alt="JavaScript" />
            </a>

            <a href="https://www.docker.com/" target="_blank" rel="noopener noreferrer" aria-label="Docker">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg" height="48" width="48" alt="Docker" />
            </a>

            <a href="https://www.mysql.com/" target="_blank" rel="noopener noreferrer" aria-label="MySQL">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg" height="48" width="48" alt="MySQL" />
            </a>

            <a href="https://www.postgresql.org/" target="_blank" rel="noopener noreferrer" aria-label="PostgreSQL">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg" height="48" width="48" alt="PostgreSQL" />
            </a>

            <a href="https://ys.mihoyo.com/" target="_blank" rel="noopener noreferrer" aria-label="Genshin Impact">
                <img src="https://img.yumeko.site/file/blog/Genshin.webp" height="48" width="48" alt="PostgreSQL" />
            </a>
        </p>


        <hr />

        <div>&nbsp;</div>
    </div>
</PageLayout>

<style>
    .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        color: var(--color-text);
        line-height: 1.6;
    }

    h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.5rem;
    }

    ul {
        list-style-type: disc;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    li {
        margin-bottom: 0.5rem;
    }

    hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
    }

    img {
        max-width: 100%;
        height: auto;
    }

    /* 优化 Markdown 样式 */
    .readme-style p {
        margin-bottom: 1rem;
    }

    .readme-style .center-text,
    .readme-style .center-block {
        text-align: center;
    }
    
    .readme-style .center-flex-wrap {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem;
    }

    /* 技术栈图标间距 */
    .readme-style p img {
        margin: 0 4px;
        vertical-align: middle;
    }

    /* --- Profile Header --- */
    .profile-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 2rem 0 1.5rem;
    }

    .avatar-container {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        overflow: hidden;
        margin-bottom: 1rem;
        box-shadow: var(--shadow-md);
        border: 3px solid var(--color-card-bg);
    }

    .avatar {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-name {
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0;
    }

    /* --- 经历 (Experience) 卡片 --- */
    .experience-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .xp-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--color-card-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        box-shadow: var(--shadow-sm);
        width: 100%;
        max-width: 400px;
    }
    .xp-card:hover {
        border-color: var(--color-primary-light);
        background: var(--color-card-hover);
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
    }

    .xp-icon {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-primary-subtle);
        border-radius: var(--radius-md);
        padding: 0.5rem;
    }
    .xp-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .xp-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        flex: 1;
    }
    .xp-title {
        font-weight: 600;
        color: var(--color-text);
        font-size: 1rem;
    }
    .xp-desc {
        color: var(--color-text-light);
        font-size: 0.875rem;
    }
    .xp-arrow {
        color: var(--color-text-muted);
        font-size: 1.25rem;
        transition: all 0.3s ease;
    }
    .xp-card:hover .xp-arrow {
        color: var(--color-primary);
        transform: translate(2px, -2px);
    }

    @media (max-width: 768px) {
        .xp-card {
            padding: 0.875rem 1rem;
        }

        .xp-icon {
            width: 40px;
            height: 40px;
        }
    }
</style>
