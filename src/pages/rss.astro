---
import PageLayout from "../layouts/PageLayout.astro";
import { getRssFeeds } from "../lib/data";
import { fetchAllFeeds, type FeedItem } from "../lib/rss";

// 构建时抓取所有启用的订阅源
const feeds = getRssFeeds({ status: "active" });
const results = await fetchAllFeeds(feeds);

// 合并所有源的文章，按日期倒序（无日期的排最后），最多展示 60 条
interface TimelineItem extends FeedItem {
    sourceTitle: string;
    sourceLink: string;
}

const MAX_TIMELINE_ITEMS = 60;

const timeline: TimelineItem[] = results
    .filter((result) => result.ok)
    .flatMap((result) =>
        result.items.map((item) => ({
            ...item,
            sourceTitle: result.title,
            sourceLink: result.link,
        })),
    )
    .sort((a, b) => (b.date || "").localeCompare(a.date || ""))
    .slice(0, MAX_TIMELINE_ITEMS);

// 日期格式化（YYYY-MM-DD）
function formatDate(iso: string): string {
    if (!iso) return "未知日期";
    return iso.slice(0, 10);
}

// 构建时间注记
const builtAt = new Date().toISOString().slice(0, 16).replace("T", " ");
---

<PageLayout title="RSS | Nayuki Blog">
    <div class="container">
        <h1 class="page-title">RSS 订阅</h1>
        <p class="page-desc">我订阅的博客与他们的最新文章。</p>

        <!-- 订阅源卡片 -->
        <section class="feed-sources">
            {
                results.map((result) => (
                    <a
                        class={`source-card ${result.ok ? "" : "source-error"}`}
                        href={result.link || result.feed.site}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <div class="source-head">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M4 11a9 9 0 0 1 9 9" />
                                <path d="M4 4a16 16 0 0 1 16 16" />
                                <circle cx="5" cy="19" r="1" />
                            </svg>
                            <span class="source-title">{result.title}</span>
                        </div>
                        <span class="source-meta">
                            {result.ok
                                ? `${result.items.length} 篇最新文章`
                                : "暂时无法获取"}
                        </span>
                    </a>
                ))
            }
        </section>

        <!-- 最新文章时间线 -->
        <section class="feed-timeline">
            <h2 class="timeline-title">最新文章</h2>

            {
                timeline.length === 0 ? (
                    <p class="timeline-empty">暂无内容，等下次构建时再来看看。</p>
                ) : (
                    <ul class="timeline-list">
                        {timeline.map((item) => (
                            <li class="timeline-item">
                                <a
                                    class="item-link"
                                    href={item.link}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <div class="item-meta">
                                        <span class="item-source">
                                            {item.sourceTitle}
                                        </span>
                                        <span class="item-date">
                                            {formatDate(item.date)}
                                        </span>
                                    </div>
                                    <h3 class="item-title">{item.title}</h3>
                                    {item.summary && (
                                        <p class="item-summary">{item.summary}</p>
                                    )}
                                </a>
                            </li>
                        ))}
                    </ul>
                )
            }
        </section>

        <p class="build-note">内容于站点构建时抓取（{builtAt} UTC）</p>
    </div>
</PageLayout>

<style>
    .container {
        max-width: 720px;
        margin: 0 auto;
    }

    .page-desc {
        text-align: center;
        color: var(--color-text-muted);
        margin: 0.5rem 0 2.5rem;
        font-size: 0.9375rem;
    }

    /* ============ 订阅源卡片 ============ */
    .feed-sources {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.875rem;
        margin-bottom: 3rem;
    }

    .source-card {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        padding: 1rem 1.125rem;
        background: var(--color-card-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition:
            border-color 0.2s ease,
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .source-card:hover {
        border-color: var(--color-text);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .source-head {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text);
    }

    .source-title {
        font-size: 0.9375rem;
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .source-meta {
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }

    /* 抓取失败的源 */
    .source-error {
        opacity: 0.55;
    }

    .source-error:hover {
        border-color: var(--color-border);
        transform: none;
        box-shadow: none;
    }

    /* ============ 文章时间线 ============ */
    .timeline-title {
        font-size: 1.125rem;
        font-weight: 700;
        margin: 0 0 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--color-border-light);
    }

    .timeline-empty {
        color: var(--color-text-muted);
        font-size: 0.9375rem;
        text-align: center;
        padding: 2rem 0;
    }

    .timeline-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .item-link {
        display: block;
        padding: 1.125rem 1.25rem;
        background: var(--color-card-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition:
            border-color 0.2s ease,
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .item-link:hover {
        border-color: var(--color-text);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .item-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.375rem;
    }

    .item-source {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-light);
        letter-spacing: 0.02em;
    }

    .item-date {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        font-variant-numeric: tabular-nums;
        flex-shrink: 0;
    }

    .item-title {
        margin: 0;
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--color-text);
        line-height: 1.4;
        transition: color 0.2s ease;
    }

    .item-link:hover .item-title {
        color: var(--color-primary);
    }

    .item-summary {
        margin: 0.5rem 0 0;
        font-size: 0.875rem;
        color: var(--color-text-light);
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* ============ 构建时间注记 ============ */
    .build-note {
        margin-top: 2.5rem;
        text-align: center;
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }

    /* ============ 移动端适配 ============ */
    @media (max-width: 639px) {
        .feed-sources {
            grid-template-columns: 1fr;
        }

        .item-link {
            padding: 1rem;
        }
    }
</style>
