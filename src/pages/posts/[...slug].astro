---
import { getCollection } from 'astro:content';
import MarkdownLayout from "../../layouts/MarkdownLayout.astro";

// 构建时获取所有文章路径
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 获取当前文章
const { entry } = Astro.props;
const { Content } = await entry.render();

// 双链预览元数据：slug → { title, date, description }
const allPosts = (await getCollection('blog')).filter(p => p.data.status === 'published');
const wikiPreviewData: Record<string, { title: string; date: string; description?: string }> = {};
for (const p of allPosts) {
  // remark-wiki-link pageResolver 会转为小写，key 需匹配
  wikiPreviewData[p.slug.toLowerCase()] = {
    title: p.data.title,
    date: p.data.date,
    description: p.data.description,
  };
}
---

<MarkdownLayout frontmatter={entry.data} wikiPreviewData={wikiPreviewData}>
  <Content />
</MarkdownLayout>
