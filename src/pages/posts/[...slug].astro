---
import { getCollection } from 'astro:content';
import MarkdownLayout from "../../layouts/MarkdownLayout.astro";

// 构建时获取所有文章路径
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 获取当前文章
const { entry } = Astro.props;
const { Content } = await entry.render();

// 所有已发布文章按日期降序
const allPosts = (await getCollection('blog'))
  .filter(p => p.data.status === 'published')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 前后文章
const idx = allPosts.findIndex(p => p.slug === entry.slug);
const prevPost = idx > 0 ? allPosts[idx - 1] : null;
const nextPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

// 双链预览元数据：slug → { title, date, description }
const wikiPreviewData: Record<string, { title: string; date: string; description?: string }> = {};
for (const p of allPosts) {
  wikiPreviewData[p.slug.toLowerCase()] = {
    title: p.data.title,
    date: p.data.date,
    description: p.data.description,
  };
}
---

<MarkdownLayout frontmatter={entry.data} wikiPreviewData={wikiPreviewData} prevPost={prevPost} nextPost={nextPost}>
  <Content />
</MarkdownLayout>
